eight='32' rx='6' fill='%230c0c0c'/&gt;&lt;text x='16' y='24' font-family='Archivo,Arial,sans-serif' font-size='23' font-weight='900' text-anchor='middle' fill='%23f2efe8'&gt;m&lt;tspan fill='%233b6dff'&gt;.&lt;/tspan&gt;&lt;/text&gt;&lt;/svg&gt;\">\n<style>\n  *{box-sizing:border-box}\n  body{margin:0;background:#0c0c0c;color:#f2efe8;font-family:'Archivo',system-ui,-apple-system,sans-serif;line-height:1.55;-webkit-font-smoothing:antialiased;overflow-x:hidden}\n  ::selection{background:#f2efe8;color:#0c0c0c}\n  img{display:block}\n  @keyframes marquee{to{transform:translateX(-50%)}}\n<\u002Fstyle>\n<\u002Fhelmet>\n\n<!-- ============ NAV ============ -->\n<header ref=\"{{ headerRef }}\" style=\"position:fixed;top:0;left:0;right:0;z-index:50;backdrop-filter:blur(10px);border-bottom:1px solid transparent;transition:background .3s,border-color .3s\">\n  <div style=\"max-width:1320px;margin:0 auto;padding:0 30px\">\n    <nav style=\"display:flex;align-items:center;justify-content:space-between;height:74px;gap:18px\">\n      <a href=\"#top\" style=\"display:inline-flex;align-items:baseline;gap:12px;text-decoration:none;color:#f2efe8\">\n        <span style=\"font-weight:900;font-size:26px;letter-spacing:-.045em;line-height:1\">mood<span style=\"color:#3b6dff\">.<\u002Fspan><\u002Fspan>\n      <\u002Fa>\n      <div style=\"display:flex;align-items:center;gap:34px\">\n        <a href=\"#piece\" style=\"font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#a9a69f;font-weight:600;text-decoration:none\">The Piece<\u002Fa>\n        <a href=\"#about\" style=\"font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:#a9a69f;font-weight:600;text-decoration:none\">About<\u002Fa>\n        <a href=\"#notify\" style=\"display:inline-block;font-weight:700;font-size:12px;letter-spacing:.2em;text-transform:uppercase;padding:12px 22px;background:#f2efe8;color:#0c0c0c;text-decoration:none\">Join<\u002Fa>\n      <\u002Fdiv>\n    <\u002Fnav>\n  <\u002Fdiv>\n<\u002Fheader>\n\n<!-- ============ HERO ============ -->\n<section id=\"top\" data-screen-label=\"hero\" style=\"min-height:100vh;display:flex;flex-wrap:wrap;border-bottom:1px solid rgba(255,255,255,.1)\">\n  <div style=\"flex:1 1 460px;min-width:320px;display:flex;flex-direction:column;justify-content:center;padding:120px 30px 60px;max-width:760px;margin-left:max(0px,calc((100vw - 1320px)/2))\">\n    <div style=\"display:flex;align-items:center;gap:14px;margin-bottom:30px\">\n      <span style=\"font-size:11px;letter-spacing:.34em;text-transform:uppercase;color:#8f8c85;font-weight:700\">001 — {{ dropName }}<\u002Fspan>\n      <span style=\"flex:1;height:1px;background:rgba(255,255,255,.14);max-width:120px\"><\u002Fspan>\n    <\u002Fdiv>\n    <h1 style=\"font-weight:900;letter-spacing:-.05em;font-size:clamp(96px,17vw,220px);line-height:.82;margin:0\">mood<span style=\"color:#3b6dff\">.<\u002Fspan><\u002Fh1>\n    <p style=\"font-size:clamp(17px,2vw,22px);color:#d8d4cb;font-weight:500;margin:30px 0 0;max-width:440px;text-wrap:pretty\">Clothing for every mood. Made by teens, for teens — <span style=\"color:#f2efe8\">mood<\u002Fspan>.<\u002Fp>\n    <form onsubmit=\"{{ submitHero }}\" style=\"display:flex;gap:0;margin-top:44px;max-width:440px;border-bottom:1px solid rgba(255,255,255,.28)\">\n      <input type=\"email\" placeholder=\"Email address\" required=\"\" style=\"flex:1;min-width:180px;background:transparent;border:none;color:#f2efe8;padding:14px 2px;font-size:15px;font-family:inherit;outline:none;letter-spacing:.01em\">\n      <button type=\"submit\" style=\"font-weight:700;font-size:12px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;border:none;background:transparent;color:#f2efe8;padding:0 4px\">Join →<\u002Fbutton>\n    <\u002Fform>\n    <p style=\"font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#8f8c85;margin-top:16px;font-weight:600\">{{ heroNote }}<\u002Fp>\n  <\u002Fdiv>\n  <div style=\"flex:1 1 420px;min-width:300px;position:relative;border-left:1px solid rgba(255,255,255,.1);overflow:hidden;min-height:60vh\">\n    <span style=\"position:absolute;top:24px;left:24px;z-index:2;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:#f2efe8;font-weight:700;mix-blend-mode:difference\">Fig.01 — Front<\u002Fspan>\n    <img src=\"0e9fa7d6-6476-4a71-8cb4-61607cccc7b1\" alt=\"mood hoodie — front\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:50% 30%\">\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ============ TICKER ============ -->\n<div style=\"border-bottom:1px solid rgba(255,255,255,.1);overflow:hidden;padding:20px 0\">\n  <div style=\"display:flex;width:max-content;animation:marquee 30s linear infinite;will-change:transform\">\n    <div style=\"display:flex;align-items:center;gap:30px;padding-right:30px;font-weight:800;font-size:14px;letter-spacing:.24em;text-transform:uppercase;color:#f2efe8;white-space:nowrap\">\n      <span>Drop 01<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan><span>Made by teens<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan><span>Wear your mood<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan><span>気分 = mood<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan>\n      <span>Drop 01<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan><span>Made by teens<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan><span>Wear your mood<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan><span>気分 = mood<\u002Fspan><span style=\"color:#57534b\">気分<\u002Fspan>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fdiv>\n\n<!-- ============ THE PIECE ============ -->\n<section id=\"piece\" data-screen-label=\"the piece\" style=\"max-width:1320px;margin:0 auto;padding:110px 30px 90px\">\n  <div data-reveal=\"\" style=\"transition:opacity .7s ease,transform .7s ease\">\n    <div style=\"display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;border-bottom:1px solid rgba(255,255,255,.1);padding-bottom:30px\">\n      <div>\n        <span style=\"font-size:11px;letter-spacing:.34em;text-transform:uppercase;color:#8f8c85;font-weight:700\">002 — The Piece<\u002Fspan>\n        <h2 style=\"font-weight:900;letter-spacing:-.03em;text-transform:uppercase;font-size:clamp(40px,6vw,84px);line-height:.94;margin:18px 0 0\">The mood<br>Hoodie<\u002Fh2>\n      <\u002Fdiv>\n      <p style=\"color:#a9a69f;max-width:360px;font-size:15px;text-wrap:pretty\">Heavyweight brushed fleece. Fanged hit on the chest, mood down the back. Our debut piece — photographed front and back.<\u002Fp>\n    <\u002Fdiv>\n\n    <div style=\"position:relative;margin-top:40px;overflow:hidden;border:1px solid rgba(255,255,255,.1)\">\n      <span style=\"position:absolute;top:22px;left:22px;z-index:2;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:#0c0c0c;font-weight:700;background:#f2efe8;padding:7px 13px\">Fig.02 — Front &amp; Back<\u002Fspan>\n      <img src=\"82a6fd5a-0256-46a5-a553-a76ad1907bfc\" alt=\"mood hoodie — front and back, in the gallery\" style=\"width:100%;height:auto\">\n    <\u002Fdiv>\n\n    <div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-top:0;border-left:1px solid rgba(255,255,255,.1)\">\n      <div style=\"border-bottom:1px solid rgba(255,255,255,.1);border-right:1px solid rgba(255,255,255,.1);padding:26px 24px\">\n        <div style=\"font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;font-weight:700\">Fabric<\u002Fdiv>\n        <div style=\"font-weight:700;font-size:17px;margin-top:8px\">400gsm brushed fleece<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"border-bottom:1px solid rgba(255,255,255,.1);border-right:1px solid rgba(255,255,255,.1);padding:26px 24px\">\n        <div style=\"font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;font-weight:700\">Graphic<\u002Fdiv>\n        <div style=\"font-weight:700;font-size:17px;margin-top:8px\">Fang chest · mood back<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"border-bottom:1px solid rgba(255,255,255,.1);border-right:1px solid rgba(255,255,255,.1);padding:26px 24px\">\n        <div style=\"font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;font-weight:700\">Fit<\u002Fdiv>\n        <div style=\"font-weight:700;font-size:17px;margin-top:8px\">Boxy · oversized<\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"border-bottom:1px solid rgba(255,255,255,.1);border-right:1px solid rgba(255,255,255,.1);padding:26px 24px\">\n        <div style=\"font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;font-weight:700\">Made by<\u002Fdiv>\n        <div style=\"font-weight:700;font-size:17px;margin-top:8px\">Two teenagers<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ============ MANIFESTO ============ -->\n<section id=\"about\" data-screen-label=\"about\" style=\"border-top:1px solid rgba(255,255,255,.1);border-bottom:1px solid rgba(255,255,255,.1)\">\n  <div data-reveal=\"\" style=\"transition:opacity .7s ease,transform .7s ease;max-width:1320px;margin:0 auto;padding:100px 30px\">\n    <span style=\"font-size:11px;letter-spacing:.34em;text-transform:uppercase;color:#8f8c85;font-weight:700\">003 — Manifesto<\u002Fspan>\n    <p style=\"font-weight:600;font-size:clamp(26px,4vw,52px);line-height:1.18;letter-spacing:-.02em;margin:30px 0 0;max-width:1040px;text-wrap:pretty\">mood is a clothing label built by two 14-year-olds. No factory floor, no boardroom — two friends making pieces we'd actually wear. Every design drops in small numbers, then it's gone. <span style=\"color:#8f8c85\">Wear your mood.<\u002Fspan><\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ============ DROP + COUNTDOWN ============ -->\n<section id=\"drop\" data-screen-label=\"drop\" style=\"max-width:1320px;margin:0 auto;padding:100px 30px\">\n  <div data-reveal=\"\" style=\"transition:opacity .7s ease,transform .7s ease;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:50px;align-items:center\">\n    <div>\n      <span style=\"font-size:11px;letter-spacing:.34em;text-transform:uppercase;color:#8f8c85;font-weight:700\">004 — First Drop<\u002Fspan>\n      <h2 style=\"font-weight:900;letter-spacing:-.03em;text-transform:uppercase;font-size:clamp(44px,6vw,80px);line-height:.92;margin:18px 0 0\">{{ dropName }}<\u002Fh2>\n      <p style=\"color:#a9a69f;margin:22px 0 0;max-width:420px;font-size:15px;text-wrap:pretty\">Our debut piece is in the works — designed by us, made in a small run. Join the list and be first when it drops.<\u002Fp>\n      <div style=\"display:flex;gap:0;margin-top:40px;border-top:1px solid rgba(255,255,255,.14);border-bottom:1px solid rgba(255,255,255,.14)\">\n        <div style=\"flex:1;padding:22px 6px;text-align:center;border-right:1px solid rgba(255,255,255,.14)\">\n          <div style=\"font-weight:900;font-size:clamp(32px,5vw,46px);line-height:1;letter-spacing:-.02em\">{{ cd.d }}<\u002Fdiv>\n          <div style=\"font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;margin-top:8px;font-weight:700\">Days<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1;padding:22px 6px;text-align:center;border-right:1px solid rgba(255,255,255,.14)\">\n          <div style=\"font-weight:900;font-size:clamp(32px,5vw,46px);line-height:1;letter-spacing:-.02em\">{{ cd.h }}<\u002Fdiv>\n          <div style=\"font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;margin-top:8px;font-weight:700\">Hrs<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1;padding:22px 6px;text-align:center;border-right:1px solid rgba(255,255,255,.14)\">\n          <div style=\"font-weight:900;font-size:clamp(32px,5vw,46px);line-height:1;letter-spacing:-.02em\">{{ cd.m }}<\u002Fdiv>\n          <div style=\"font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;margin-top:8px;font-weight:700\">Min<\u002Fdiv>\n        <\u002Fdiv>\n        <div style=\"flex:1;padding:22px 6px;text-align:center\">\n          <div style=\"font-weight:900;font-size:clamp(32px,5vw,46px);line-height:1;letter-spacing:-.02em\">{{ cd.s }}<\u002Fdiv>\n          <div style=\"font-size:10px;letter-spacing:.24em;text-transform:uppercase;color:#8f8c85;margin-top:8px;font-weight:700\">Sec<\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"position:relative;overflow:hidden;border:1px solid rgba(255,255,255,.1)\">\n      <span style=\"position:absolute;top:20px;left:20px;z-index:2;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:#f2efe8;font-weight:700;mix-blend-mode:difference\">Fig.03 — Back<\u002Fspan>\n      <img src=\"29a838c3-fea3-4483-aaff-33df4729cf64\" alt=\"mood hoodie — back\" style=\"width:100%;height:auto\">\n    <\u002Fdiv>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ============ CTA ============ -->\n<section id=\"notify\" data-screen-label=\"notify\" style=\"border-top:1px solid rgba(255,255,255,.1)\">\n  <div data-reveal=\"\" style=\"transition:opacity .7s ease,transform .7s ease;max-width:1320px;margin:0 auto;padding:110px 30px;text-align:center\">\n    <span style=\"font-size:13px;letter-spacing:.3em;text-transform:uppercase;color:#8f8c85;font-weight:700\">mood<\u002Fspan>\n    <h2 style=\"font-weight:900;letter-spacing:-.03em;text-transform:uppercase;font-size:clamp(40px,7vw,96px);line-height:.9;margin:20px 0 0\">Don't miss<br>the drop<\u002Fh2>\n    <p style=\"color:#a9a69f;margin:22px auto 0;max-width:400px;font-size:15px;text-wrap:pretty\">Drops are small and they go fast. Get the drop notice the moment {{ dropName }} is live.<\u002Fp>\n    <form onsubmit=\"{{ submitCta }}\" style=\"display:flex;gap:0;margin:40px auto 0;max-width:460px;border-bottom:1px solid rgba(255,255,255,.28)\">\n      <input type=\"email\" placeholder=\"Email address\" required=\"\" style=\"flex:1;min-width:180px;background:transparent;border:none;color:#f2efe8;padding:14px 2px;font-size:15px;font-family:inherit;outline:none;text-align:left\">\n      <button type=\"submit\" style=\"font-weight:700;font-size:12px;letter-spacing:.2em;text-transform:uppercase;cursor:pointer;border:none;background:transparent;color:#f2efe8;padding:0 4px\">Join →<\u002Fbutton>\n    <\u002Fform>\n    <p style=\"font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#3b6dff;font-weight:600;margin-top:16px;min-height:16px\">{{ ctaNote }}<\u002Fp>\n  <\u002Fdiv>\n<\u002Fsection>\n\n<!-- ============ FOOTER ============ -->\n<footer style=\"border-top:1px solid rgba(255,255,255,.1)\">\n  <div style=\"max-width:1320px;margin:0 auto;padding:44px 30px 60px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:22px\">\n    <a href=\"#top\" style=\"display:inline-flex;align-items:baseline;gap:11px;text-decoration:none;color:#f2efe8\">\n      <span style=\"font-weight:900;font-size:22px;letter-spacing:-.045em\">mood<span style=\"color:#3b6dff\">.<\u002Fspan><\u002Fspan>\n    <\u002Fa>\n    <div style=\"display:flex;gap:26px\">\n      <a href=\"#\" aria-label=\"Instagram\" style=\"font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#a9a69f;text-decoration:none;font-weight:600\">Instagram<\u002Fa>\n      <a href=\"#\" aria-label=\"TikTok\" style=\"font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#a9a69f;text-decoration:none;font-weight:600\">TikTok<\u002Fa>\n      <a href=\"mailto:hello@example.com\" style=\"font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#a9a69f;text-decoration:none;font-weight:600\">Email<\u002Fa>\n    <\u002Fdiv>\n    <p style=\"color:#57534b;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;width:100%;margin:0\">© {{ year }} mood — made by teens, for teens<\u002Fp>\n  <\u002Fdiv>\n<\u002Ffooter>\n\n\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;showKanjiBg&quot;:{&quot;editor&quot;:&quot;boolean&quot;,&quot;default&quot;:true,&quot;tsType&quot;:&quot;boolean&quot;,&quot;section&quot;:&quot;Style&quot;},&quot;dropName&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;Drop 01&quot;,&quot;tsType&quot;:&quot;string&quot;,&quot;section&quot;:&quot;Content&quot;}}\">\nclass Component extends DCLogic {\n  state = {\n    cd: { d: '00', h: '00', m: '00', s: '00' },\n    heroNote: \"Be first to see drop 01 — no spam.\",\n    ctaNote: \"\"\n  };\n  headerRef = React.createRef();\n\n  componentDidMount() {\n    this._onScroll = () => {\n      const s = window.scrollY > 20;\n      const h = this.headerRef.current;\n      if (h) {\n        h.style.background = s ? 'rgba(12,12,12,.92)' : 'linear-gradient(180deg, rgba(12,12,12,.65), rgba(12,12,12,0))';\n        h.style.borderBottomColor = s ? 'rgba(255,255,255,.1)' : 'transparent';\n      }\n    };\n    window.addEventListener('scroll', this._onScroll);\n    this._onScroll();\n\n    this._io = new IntersectionObserver((entries) => {\n      entries.forEach(e => {\n        if (e.isIntersecting) { e.target.style.opacity = '1'; e.target.style.transform = 'none'; this._io.unobserve(e.target); }\n      });\n    }, { threshold: 0.12 });\n    document.querySelectorAll('[data-reveal]').forEach(el => {\n      el.style.opacity = '0';\n      el.style.transform = 'translateY(24px)';\n      this._io.observe(el);\n    });\n\n    const drop = new Date(new Date().getFullYear(), new Date().getMonth() + 1, 1).getTime();\n    const pad = n => String(n).padStart(2, '0');\n    this._tick = () => {\n      let diff = Math.max(0, drop - Date.now());\n      const d = Math.floor(diff / 864e5); diff -= d * 864e5;\n      const h = Math.floor(diff / 36e5); diff -= h * 36e5;\n      const m = Math.floor(diff / 6e4); diff -= m * 6e4;\n      const s = Math.floor(diff / 1e3);\n      this.setState({ cd: { d: pad(d), h: pad(h), m: pad(m), s: pad(s) } });\n    };\n    this._tick();\n    this._cd = setInterval(this._tick, 1000);\n  }\n\n  componentWillUnmount() {\n    window.removeEventListener('scroll', this._onScroll);\n    clearInterval(this._cd);\n    if (this._io) this._io.disconnect();\n  }\n\n  submit(which, e) {\n    e.preventDefault();\n    const input = e.target.querySelector('input');\n    const email = (input.value || '').trim();\n    if (!email) return;\n    try {\n      const list = JSON.parse(localStorage.getItem('mood_waitlist') || '[]');\n      if (!list.includes(email)) { list.push(email); localStorage.setItem('mood_waitlist', JSON.stringify(list)); }\n    } catch (_) {}\n    input.value = '';\n    if (which === 'hero') this.setState({ heroNote: \"You're on the list ✓\" });\n    else this.setState({ ctaNote: \"You're on the list ✓ — see you at the drop.\" });\n  }\n\n  renderVals() {\n    return {\n      dropName: this.props.dropName || 'Drop 01',\n      showKanji: this.props.showKanjiBg !== false,\n      cd: this.state.cd,\n      heroNote: this.state.heroNote,\n      ctaNote: this.state.ctaNote,\n      submitHero: (e) => this.submit('hero', e),\n      submitCta: (e) => this.submit('cta', e),\n      year: new Date().getFullYear(),\n      headerRef: this.headerRef\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>
</html>
